<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TOOLBAR -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Setelan"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingStart="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="16dp"/>

        <!-- ═══════════════════════════════════════════ -->
        <!--          SECTION: BUDGET & KEUANGAN        -->
        <!-- ═══════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BUDGET &amp; KEUANGAN"
            android:textColor="@color/teal_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:paddingStart="20dp"
            android:paddingBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Budget Total -->
                <LinearLayout
                    android:id="@+id/item_budget_total"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_wallet" android:contentDescription="Budget"
                        app:tint="@color/teal_primary"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Budget limit total" android:textColor="@color/text_primary" android:textSize="14sp"/>
                        <TextView android:id="@+id/tv_budget_total_value"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Rp 3.900.000 / bulan" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    </LinearLayout>
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_right" android:contentDescription="Edit"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginStart="48dp"/>

                <!-- Budget per Kategori -->
                <LinearLayout
                    android:id="@+id/item_budget_kategori"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_category" android:contentDescription="Kategori"
                        app:tint="@color/teal_primary"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Budget per kategori" android:textColor="@color/text_primary" android:textSize="14sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Atur limit untuk setiap kategori" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    </LinearLayout>
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_right" android:contentDescription="Edit"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginStart="48dp"/>

                <!-- Reset Budget -->
                <LinearLayout
                    android:id="@+id/item_reset_budget"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_refresh" android:contentDescription="Reset"
                        app:tint="@color/teal_primary"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Reset budget otomatis" android:textColor="@color/text_primary" android:textSize="14sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Setiap awal bulan" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    </LinearLayout>
                    <Switch
                        android:id="@+id/switch_reset_budget"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumb="@null"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════ -->
        <!--           SECTION: NOTIFIKASI              -->
        <!-- ═══════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NOTIFIKASI"
            android:textColor="@color/teal_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:paddingStart="20dp"
            android:paddingBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Notif Peringatan Budget -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_bell" android:contentDescription="Notifikasi"
                        app:tint="@color/teal_primary"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Peringatan budget" android:textColor="@color/text_primary" android:textSize="14sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Notif saat mendekati limit" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    </LinearLayout>
                    <Switch
                        android:id="@+id/switch_notif_budget"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginStart="48dp"/>

                <!-- Threshold Peringatan -->
                <LinearLayout
                    android:id="@+id/item_threshold"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_percent" android:contentDescription="Persen"
                        app:tint="@color/teal_primary"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Batas peringatan" android:textColor="@color/text_primary" android:textSize="14sp"/>
                        <TextView android:id="@+id/tv_threshold_value"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="80% dari limit" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    </LinearLayout>
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_right" android:contentDescription="Edit"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginStart="48dp"/>

                <!-- Pengingat harian -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_clock" android:contentDescription="Pengingat"
                        app:tint="@color/teal_primary"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pengingat input harian" android:textColor="@color/text_primary" android:textSize="14sp"/>
                        <TextView android:id="@+id/tv_reminder_time"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Setiap 21:00" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    </LinearLayout>
                    <Switch
                        android:id="@+id/switch_reminder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════ -->
        <!--            SECTION: TAMPILAN               -->
        <!-- ═══════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TAMPILAN"
            android:textColor="@color/teal_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:paddingStart="20dp"
            android:paddingBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Dark Mode -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_moon" android:contentDescription="Dark mode"
                        app:tint="@color/teal_primary"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Dark mode"
                        android:textColor="@color/text_primary" android:textSize="14sp" android:layout_marginStart="12dp"/>
                    <Switch
                        android:id="@+id/switch_dark_mode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════ -->
        <!--            SECTION: DATA                   -->
        <!-- ═══════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DATA"
            android:textColor="@color/teal_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:paddingStart="20dp"
            android:paddingBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="32dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Export -->
                <LinearLayout
                    android:id="@+id/item_export"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_download" android:contentDescription="Export"
                        app:tint="@color/teal_primary"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Export laporan" android:textColor="@color/text_primary" android:textSize="14sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Simpan ke PDF atau Excel" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    </LinearLayout>
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_right" android:contentDescription="Export"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginStart="48dp"/>

                <!-- Reset Data -->
                <LinearLayout
                    android:id="@+id/item_reset_data"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_trash" android:contentDescription="Reset"
                        app:tint="@color/expense_red"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Reset semua data" android:textColor="@color/expense_red" android:textSize="14sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Hapus seluruh riwayat transaksi" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    </LinearLayout>
                    <ImageView android:layout_width="16dp" android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_right" android:contentDescription="Reset"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>