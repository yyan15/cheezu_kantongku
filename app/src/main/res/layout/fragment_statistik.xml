<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TOOLBAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:paddingTop="48dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Statistik"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Toggle Bulanan/Mingguan -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_toggle_track"
                android:padding="3dp">

                <TextView
                    android:id="@+id/toggle_bulanan"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Bulanan"
                    android:textSize="12sp"
                    android:textColor="@android:color/white"
                    android:background="@drawable/bg_toggle_active"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/toggle_mingguan"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Mingguan"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
        </LinearLayout>

        <!-- RINGKASAN CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/teal_primary"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:weightSum="3">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Total" android:textColor="#CCFFFFFF" android:textSize="11sp"/>
                    <TextView android:id="@+id/tv_total_pengeluaran"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="2,66Jt" android:textColor="@android:color/white"
                        android:textSize="16sp" android:textStyle="bold" android:layout_marginTop="2dp"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="match_parent"
                    android:background="#33FFFFFF" android:layout_marginTop="4dp" android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Terbesar" android:textColor="#CCFFFFFF" android:textSize="11sp"/>
                    <TextView android:id="@+id/tv_kategori_terbesar"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Makan" android:textColor="@android:color/white"
                        android:textSize="16sp" android:textStyle="bold" android:layout_marginTop="2dp"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="match_parent"
                    android:background="#33FFFFFF" android:layout_marginTop="4dp" android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Transaksi" android:textColor="#CCFFFFFF" android:textSize="11sp"/>
                    <TextView android:id="@+id/tv_jumlah_transaksi"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="24" android:textColor="@android:color/white"
                        android:textSize="16sp" android:textStyle="bold" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- BAR CHART CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pengeluaran 6 bulan terakhir"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp"/>

                <!-- MPAndroidChart BarChart -->
                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/bar_chart"
                    android:layout_width="match_parent"
                    android:layout_height="180dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- BREAKDOWN KATEGORI CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="100dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Per kategori bulan ini"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="14dp"/>

                <!-- Kategori Item: Makan -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="5dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="🍜  Makan"
                            android:textColor="@color/text_primary" android:textSize="13sp"/>
                        <TextView android:id="@+id/tv_pct_makan"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Rp 840.000 · 32%" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                    </LinearLayout>
                    <ProgressBar android:id="@+id/progress_makan"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent" android:layout_height="6dp"
                        android:max="100" android:progress="32"
                        android:progressTint="@color/teal_primary"
                        android:progressBackgroundTint="@color/surface_secondary"/>
                </LinearLayout>

                <!-- Kategori Item: Transport -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="5dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="🚌  Transport"
                            android:textColor="@color/text_primary" android:textSize="13sp"/>
                        <TextView android:id="@+id/tv_pct_transport"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Rp 530.000 · 20%" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                    </LinearLayout>
                    <ProgressBar android:id="@+id/progress_transport"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent" android:layout_height="6dp"
                        android:max="100" android:progress="20"
                        android:progressTint="@color/icon_color_transport"
                        android:progressBackgroundTint="@color/surface_secondary"/>
                </LinearLayout>

                <!-- Kategori Item: Belanja -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="5dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="🛒  Belanja"
                            android:textColor="@color/text_primary" android:textSize="13sp"/>
                        <TextView android:id="@+id/tv_pct_belanja"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Rp 790.000 · 30%" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                    </LinearLayout>
                    <ProgressBar android:id="@+id/progress_belanja"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent" android:layout_height="6dp"
                        android:max="100" android:progress="30"
                        android:progressTint="@color/icon_color_belanja"
                        android:progressBackgroundTint="@color/surface_secondary"/>
                </LinearLayout>

                <!-- Kategori Item: Hiburan -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="5dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="🎮  Hiburan"
                            android:textColor="@color/text_primary" android:textSize="13sp"/>
                        <TextView android:id="@+id/tv_pct_hiburan"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Rp 500.000 · 18%" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                    </LinearLayout>
                    <ProgressBar android:id="@+id/progress_hiburan"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent" android:layout_height="6dp"
                        android:max="100" android:progress="18"
                        android:progressTint="@color/icon_color_hiburan"
                        android:progressBackgroundTint="@color/surface_secondary"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>