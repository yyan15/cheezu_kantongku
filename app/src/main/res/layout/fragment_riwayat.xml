<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- TOOLBAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Riwayat"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_filter"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_surface"
            android:src="@drawable/ic_filter"
            android:contentDescription="Filter" />
    </LinearLayout>

    <!-- SEARCH BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_search_bar"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:padding="12dp">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_search"
            android:contentDescription="Cari" />

        <EditText
            android:id="@+id/et_search"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Cari transaksi..."
            android:textColorHint="@color/text_hint"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:background="@null"
            android:layout_marginStart="10dp"
            android:maxLines="1"
            android:inputType="text" />
    </LinearLayout>

    <!-- FILTER CHIP ROW -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chip_semua"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Semua"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_chip_active"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chip_makan"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Makan"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_chip_normal"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chip_transport"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Transport"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_chip_normal"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chip_belanja"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Belanja"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_chip_normal"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chip_hiburan"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Hiburan"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:background="@drawable/bg_chip_normal"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- RECYCLER VIEW LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_riwayat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:itemCount="6"
        tools:listitem="@layout/item_transaksi" />

</LinearLayout>